# Port for the Express API
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_gallery

# Secret used to sign JWT tokens - change this to a long random string
JWT_SECRET=change_this_to_a_long_random_secret

# Directory (relative to backend/) where uploaded files are stored
UPLOAD_DIR=uploads

# Credentials for the single admin account (used by `npm run seed`)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password
