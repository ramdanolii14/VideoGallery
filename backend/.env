# Port for the Express API
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:Ramdan2006!@localhost:5432/video_gallery

# Secret used to sign JWT tokens - change this to a long random string
JWT_SECRET=thisisaverylongrandomsecretthatyoushouldchangeinproduction

# Directory (relative to backend/) where uploaded files are stored
UPLOAD_DIR=uploads

# Credentials for the single admin account (used by `npm run seed`)
ADMIN_USERNAME=ramdan
ADMIN_EMAIL=developer@nyanpixel.my.id
ADMIN_PASSWORD=Ramdan2006!
